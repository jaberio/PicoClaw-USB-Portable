# ============================================================================
# PicoClaw Portable - Pinned Release Manifest
# ============================================================================
# Single source of truth for which PicoClaw release the portable wrapper uses.
# Bump VERSION + the SHA256s in lockstep to upgrade. Both setup-windows.ps1
# and setup-unix.sh source this file.
#
# Verify against the official release page:
#   https://github.com/sipeed/picoclaw/releases/tag/<VERSION>
# ============================================================================

VERSION=v0.2.8

# Asset filename templates per platform.
# These are interpolated with VERSION-without-the-v at runtime.
ASSET_WINDOWS_X86_64=picoclaw_Windows_x86_64.zip
ASSET_WINDOWS_AARCH64=picoclaw_Windows_arm64.zip
ASSET_LINUX_X86_64=picoclaw_Linux_x86_64.tar.gz
ASSET_LINUX_AARCH64=picoclaw_Linux_arm64.tar.gz
ASSET_LINUX_ARMV7=picoclaw_Linux_armv7.tar.gz
ASSET_LINUX_ARMV6=picoclaw_Linux_armv6.tar.gz
ASSET_LINUX_RISCV64=picoclaw_Linux_riscv64.tar.gz
ASSET_MACOS_X86_64=picoclaw_Darwin_x86_64.tar.gz
ASSET_MACOS_AARCH64=picoclaw_Darwin_arm64.tar.gz

# --- SHA256 hashes (from official GitHub release page) ---------------------
