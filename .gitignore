# PicoClaw Portable - keep user/runtime data out of git

# User data (config, sessions, secrets, memory) - NEVER COMMIT
data/

# Downloaded binaries and cache
.cache/

# Runtime status files
*.flag
*.log
*.pid
*.lock

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# PicoClaw migration backups
*.bak
